FROM node:lts-alpine3.23

WORKDIR /app

# 1. Corepack setup
ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable && corepack prepare pnpm@latest --activate

# 2. Copy package files
COPY package.json pnpm-lock.yaml ./

# 3. THE PNPM 11 "CI MODE" CONFIG
ENV CI=true
# Bypasses the "Approve Builds" security gate entirely
ENV PNPM_CONFIG_DANGEROUSLY_ALLOW_ALL_BUILDS=true
# Bypasses the "No TTY" directory removal error
ENV PNPM_CONFIG_CONFIRM_MODULES_PURGE=true

# 4. Standard install
# Using --no-frozen-lockfile ensures pnpm can self-heal any 
# version mismatches between your host and the container.
RUN pnpm install --no-frozen-lockfile

# 5. Copy the rest
COPY . .

EXPOSE 3000
CMD ["pnpm", "dev"]